# Base de datos MySQL
DATABASE_URL=mysql://usuario:password@localhost:3306/inscripcion_talleres

# Seguridad JWT - cambiar por un string secreto largo
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Servidor
PORT=3000
NODE_ENV=development

# CORS - URL permitida del frontend
CORS_ORIGIN=http://localhost:5173

# Email (opcional, para restablecimiento de contraseña)
# Si no se configura, en desarrollo se devuelve el token en la respuesta
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@wishdin.com

# URL de la API para el frontend
VITE_API_URL=http://localhost:3000/api